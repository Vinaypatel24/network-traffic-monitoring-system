# Environment Variables — Copy this to .env and fill in values
# NEVER commit .env to Git

# ── PostgreSQL ─────────────────────────────────
DB_PASSWORD=change_me_strong_password_here

# ── JWT (HS256) ────────────────────────────────
# Must be at least 32 characters. Generate with:
#   openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_BASE64_STRING_NEVER_HARDCODE_THIS

# ── Token Expiry ───────────────────────────────
JWT_EXPIRY_MS=900000          # 15 minutes in milliseconds
REFRESH_TOKEN_EXPIRY_DAYS=7

# ── CORS ───────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80
